# Server
PORT=3000
NODE_ENV=development

# PostgreSQL — create these with: createdb wikirace && createdb wikirace_test
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/wikirace
TEST_DATABASE_URL=postgresql://postgres:your_password@localhost:5432/wikirace_test

# JWT — use long random strings in production (e.g. openssl rand -hex 32)
JWT_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh

# Network — set to your machine's local IP so Expo Go on iPhone can reach the server
# Run `ipconfig` and look for your WiFi IPv4 address
SERVER_HOST=192.168.0.x
